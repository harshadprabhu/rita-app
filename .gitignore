# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
dist2/
dist3/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# personal notes that might contain secrets/keys — never commit these
RITA.txt
notes.txt
secrets.txt
credentials.txt
*-notes.txt
*.secrets

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
supabase/.temp/

# Firebase service-account private keys — these authorise sending push as us.
# They belong in Supabase secrets (FCM_SERVICE_ACCOUNT), never in the repo.
# NOTE: google-services.json is intentionally NOT ignored — it ships inside the
# app and holds no private key.
*-firebase-adminsdk-*.json
service-account*.json
**/firebase-adminsdk*.json
